{
  "name": "reach-relay-leaderboard-worker",
  "version": "0.0.1",
  "private": true,
  "description": "Cloudflare Worker + D1 leaderboard backend for Reach the Relay.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "schema:apply": "wrangler d1 execute reach-relay-leaderboard --file=./schema.sql --remote",
    "schema:apply-local": "wrangler d1 execute reach-relay-leaderboard --file=./schema.sql --local",
    "tail": "wrangler tail",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241106.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.86.0"
  }
}
