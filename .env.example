# Copy this file to `.env.local` (gitignored) and fill in values as needed.
# Only variables prefixed with `VITE_` are exposed to the browser at runtime;
# the rest are available to Node tooling / build scripts only.

# --- Game diagnostics -------------------------------------------------------
# Toggles the in-memory combat logger + `L`-key copy-to-clipboard hotkey.
#   'true'  → force enabled (logs recorded, hotkey active, mirrored to console)
#   'false' → force disabled (log() is a no-op, hotkey shows "copy failed")
#   unset   → defaults to enabled in `vite dev`, disabled in production builds
# VITE_DEBUG_LOG=true

# --- External service API keys (Node-side only, not exposed to browser) ----
# SpriteCook — used by the MCP integration for AI sprite/animation generation.
# Obtain from https://spritecook.ai
SPRITECOOK_API_KEY=sc_live_your_key_here

# ElevenLabs — used by the MCP integration for AI SFX / music generation.
# Obtain from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your_key_here
