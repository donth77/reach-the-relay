# Copy this file to `.env.local` (gitignored) and fill in values as needed.
# Only variables prefixed with `VITE_` are exposed to the browser at runtime;
# the rest are available to Node tooling / build scripts only.

# --- Game diagnostics -------------------------------------------------------
# Toggles the in-memory combat logger + `L`-key copy-to-clipboard hotkey.
#   'true'  → force enabled (logs recorded, hotkey active, mirrored to console)
#   'false' → force disabled (log() is a no-op, hotkey shows "copy failed")
#   unset   → defaults to enabled in `vite dev`, disabled in production builds
# VITE_DEBUG_LOG=true

# --- Vibe Jam 2026 webring --------------------------------------------------
# Bakes "jam mode" into the build so the Vibe Jam exit portal (VIBE JAM ▼
# label at the doorway) is always visible and the doorway trigger always
# redirects to vibejam.cc/portal/2026. Set this for the itch.io / jam
# submission build, leave unset for any standalone / post-jam release.
# When unset, jam mode still activates dynamically if the URL contains
# `?jam=1` or `?portal=true`.
#   '1' → force jam mode on (portal visible + trigger live on every load)
#   unset / anything else → jam mode gated on URL params only
# VITE_JAM_MODE=1

# --- Leaderboard backend ----------------------------------------------------
# URL of the Cloudflare Worker that hosts the leaderboard API. The Worker
# code lives under `worker/` — deploy it with `cd worker && npm run deploy`,
# then paste the resulting `*.workers.dev` URL here. When unset, the game
# falls back to localStorage-only scores.
# VITE_LEADERBOARD_API=https://reach-relay-leaderboard.<your-account>.workers.dev

# Debug toggle: surfaces a [ TEST SUBMIT (PROD) ] button on the victory screen
# and includes the submit `source` (remote / local) in the "Submitted!" modal
# so you can confirm the Worker actually accepted the write. Use to diagnose
# cases where a run appears to submit but the entry never shows up on the
# remote leaderboard.
#   'true' → debug button + diagnostic modal enabled
#   unset / anything else → disabled
# VITE_DEBUG_LEADERBOARD_PROD=true

# --- External service API keys (Node-side only, not exposed to browser) ----
# SpriteCook — used by the MCP integration for AI sprite/animation generation.
# Obtain from https://spritecook.ai
SPRITECOOK_API_KEY=sc_live_your_key_here

# ElevenLabs — used by the MCP integration for AI SFX / music generation.
# Obtain from https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=sk_your_key_here
